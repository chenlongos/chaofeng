# Copy these values into your shell or .env file and adjust paths for your machine.
PROJECT_ROOT=/path/to/agent_vla
LEROBOT_HOME=$HOME/lerobot
CONDA_SH=$HOME/miniforge3/etc/profile.d/conda.sh
CONDA_ENV=lerobot
AGENT_VLA_CONFIG=/path/to/agent_vla/configs/app.yaml
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8010
VLA_SERVICE_HOST=127.0.0.1
VLA_SERVICE_PORT=8011
LLM_SERVICE_HOST=127.0.0.1
LLM_SERVICE_PORT=8012
